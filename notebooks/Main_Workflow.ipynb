# Install the library 

from probosed.slope import stability
from probosed.transport import agents
from probosed.core_ml import labeler


# Start the  VCD transcription
my_labeler = labeler.VCDLabeler(
    patch_folder='/content/drive/MyDrive/patches',
    output_csv='vcd_data.csv',
    authors=['Amy Gough', 'Observer_B', 'Observer_C']
)
my_labeler.start()


# Run the Probabilistic Slope Model
slope_engine = stability.ProbabilisticSlopeModel()
forcing = [0.1, 0.5, 1.2, 0.4] # Placeholder for seismic forcing
q_results = slope_engine.run_ensemble(forcing_series=forcing)
